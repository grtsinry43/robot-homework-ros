<?xml version="1.0"?>
<!-- Panda arm + hand visuals with gz_ros2_control (arm joints only). -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="panda">
  <xacro:property name="initial_positions" value="${xacro.load_yaml('$(find my_panda_moveit_config)/config/initial_positions.yaml')['initial_positions']}"/>

  <xacro:include filename="$(find moveit_resources_panda_description)/urdf/panda.urdf"/>

  <!-- Fixed base: without this the whole model is a free body in Gazebo physics. -->
  <link name="world"/>
  <joint name="panda_world_joint" type="fixed">
    <parent link="world"/>
    <child link="panda_link0"/>
  </joint>

  <ros2_control name="panda_gz_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <xacro:macro name="panda_gz_joint" params="joint_name">
      <joint name="${joint_name}">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_positions[joint_name]}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </xacro:macro>
    <xacro:panda_gz_joint joint_name="panda_joint1"/>
    <xacro:panda_gz_joint joint_name="panda_joint2"/>
    <xacro:panda_gz_joint joint_name="panda_joint3"/>
    <xacro:panda_gz_joint joint_name="panda_joint4"/>
    <xacro:panda_gz_joint joint_name="panda_joint5"/>
    <xacro:panda_gz_joint joint_name="panda_joint6"/>
    <xacro:panda_gz_joint joint_name="panda_joint7"/>
    <xacro:panda_gz_joint joint_name="panda_finger_joint1"/>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find panda_sim_bringup)/config/panda_gz_ros2_control.yaml</parameters>
      <ros>
        <remapping>/joint_states:=/joint_states_hw</remapping>
      </ros>
    </plugin>
  </gazebo>

  <!-- Reduce joint sag before controllers claim position interfaces. -->
  <xacro:macro name="panda_gz_joint_damping" params="joint_name">
    <gazebo reference="${joint_name}">
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </gazebo>
  </xacro:macro>
  <xacro:panda_gz_joint_damping joint_name="panda_joint1"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint2"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint3"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint4"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint5"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint6"/>
  <xacro:panda_gz_joint_damping joint_name="panda_joint7"/>
  <xacro:panda_gz_joint_damping joint_name="panda_finger_joint1"/>

  <!-- Physical grasp: one DetachableJoint per graspable object. The plugin creates a
       real fixed joint between panda_hand and the object's link when its attach_topic
       gets a msgs.Empty, and removes it on detach_topic. gazebo_gripper_sim.py drives
       these topics (no more set_pose dragging). child_link is "link" for every object
       model in pick_place_desk.sdf. -->
  <!-- parent_link must be a link that survives URDF->SDF fixed-joint reduction in gz.
       panda_hand / panda_link8 are fixed-jointed and get collapsed into panda_link7,
       so the hand is rigidly part of panda_link7 — that's the valid attach parent. -->
  <xacro:macro name="grasp_joint" params="object">
    <gazebo>
      <plugin filename="ignition-gazebo-detachable-joint-system"
              name="ignition::gazebo::systems::DetachableJoint">
        <parent_link>panda_link7</parent_link>
        <child_model>${object}</child_model>
        <child_link>link</child_link>
        <attach_topic>/grasp/${object}/attach</attach_topic>
        <detach_topic>/grasp/${object}/detach</detach_topic>
        <output_topic>/grasp/${object}/state</output_topic>
        <suppress_child_warning>true</suppress_child_warning>
      </plugin>
    </gazebo>
  </xacro:macro>
  <xacro:grasp_joint object="red_block_01"/>
  <xacro:grasp_joint object="green_block_01"/>
</robot>
